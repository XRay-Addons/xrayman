{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UserPageConfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["routes"],

  "properties": {
    "routes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_prefix", "user_prefix"],

      "properties": {
        "api_prefix": {
          "type": "string",
          "description": "prefix for api requests"
        },

        "user_prefix": {
          "type": "string",
          "description": "prefix for user page spa"
        }
      }
    }
  }
}

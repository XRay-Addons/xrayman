---
import Title from "@xrayman/shared/astro/primitives/Title.astro";
import Card from "@xrayman/shared/astro/primitives/Card.astro";
import I18NText from "@xrayman/shared/astro/primitives/I18nText.astro";
import UsersTable from "@/vue/components/islands/users-table/UsersTable.vue";
import AddUserDialog from "./AddUserDialog.astro";
---

<Card class="mb-2">
  <Title class="col-6 mb-2">
    <I18NText data-i18n="cards.users.title" />
  </Title>

  <UsersTable client:only="vue" />

  <AddUserDialog />
</Card>

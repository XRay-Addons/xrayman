---
import Info from "@xrayman/shared/astro/primitives/Info.astro";
import Input from "@xrayman/shared/astro/primitives/Input.astro";
import Card from "@xrayman/shared/astro/primitives/Card.astro";
import Title from "@xrayman/shared/astro/primitives/Title.astro";
import Button from "@xrayman/shared/astro/primitives/Button.astro";
import SuccessMsg from "@xrayman/shared/astro/primitives/SuccessMsg.astro";
import I18NText from "@xrayman/shared/astro/primitives/I18nText.astro";
---

<add-sub-header-page class="row w-100 g-0 justify-content-center">
  <Card class="col-6">
    <Title class="col-8">
      <I18NText data-i18n="add-sub-header.title" />
    </Title>

    <Info>
      <I18NText data-i18n="add-sub-header.request.key.info" />
    </Info>

    <Input
      data-part="endpoint-input"
      data-i18n-placeholder="add-sub-header.request.key.placeholder"
    />

    <Info>
      <I18NText data-i18n="add-sub-header.request.value.info" />
    </Info>

    <Input
      data-part="accesskey-input"
      data-i18n-placeholder="add-sub-header.request.value.placeholder"
      class="mb-2"
    />
    <div class="row g-0 justify-content-center">
      <Button data-part="submit-input" class="col-8">
        <I18NText data-i18n="add-sub-header.submit-btn.info" />
      </Button>
    </div>

    <div data-part="success-result" hidden>
      <SuccessMsg class="col-8">
        <I18NText data-i18n="add-sub-header.response.info" />
      </SuccessMsg>
    </div>
  </Card>

  <script>
    import { newSubHeader } from "@/services/api/client";
    import { notifyApiError } from "@/runtime/notifications/use-notifications";
    import { reloadNodes } from "@/actions/nodes";
    import type { ResettableElement } from "@xrayman/shared/astro/types/Resettable";
    import { PartedElement } from "@xrayman/shared/runtime/dom/parted-element";

    class AddSubHeaderPage extends PartedElement implements ResettableElement {
      private keyInputEl!: HTMLInputElement;
      private valueInputEl!: HTMLInputElement;
      private inputSubmitEl!: HTMLButtonElement;
      private successResultEl!: HTMLElement;

      connectedCallback() {
        this.keyInputEl = this.pt<HTMLInputElement>("key-input");
        this.valueInputEl = this.pt<HTMLInputElement>("value-input");
        this.inputSubmitEl = this.pt<HTMLButtonElement>("submit-input");
        this.successResultEl = this.pt<HTMLElement>("success-result");

        this.inputSubmitEl.onclick = async () => {
          const key = this.keyInputEl.value;
          const value = this.valueInputEl?.value;
          if (key.length == 0 || value.length == 0) {
            return;
          }

          // reset and hide
          this.successResultEl?.setAttribute("hidden", "true");

          const response = await newSubHeader(key, value);
          if (!response.ok) {
            notifyApiError("new_sub_header", response.reason);
            return;
          }
          reloadNodes({ quiet: true });

          // show back
          this.successResultEl?.removeAttribute("hidden");
        };
      }

      disconnectedCallback() {}

      reset() {
        this.keyInputEl.value = "";
        this.valueInputEl.value = "";
        this.successResultEl.hidden = true;
      }
    }

    customElements.define("add-sub-header-page", AddSubHeaderPage);
  </script>
</add-sub-header-page>

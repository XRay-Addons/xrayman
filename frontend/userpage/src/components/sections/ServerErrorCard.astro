---
import Error from "./Error.astro";

const errorImg = "./error.gif";
const errorColor = "white";
---

<server-error-card>
  <Error src={errorImg} color={errorColor}>
    <div data-i18n="servererror.main"></div>
    <div data-part="servererror.reason"></div>
  </Error>
</server-error-card>

<style>
  server-error {
    display: contents;
  }
</style>

<script>
  import { stateSignal } from "@/state/signals";
  import { State } from "@/state/state";
  import { PartedElement } from "@xrayman/shared/runtime/dom/parted-element";

  class ServerErrorCard extends PartedElement {
    private unsub?: () => void;

    connectedCallback() {
      const reasonSpan = this.pt<HTMLElement>("servererror.reason");
      this.unsub = stateSignal.subscribe((state) => {
        if (state.status === State.ServerError) {
          console.log("state = server error");
          const i18nReason = `servererror.reason.${state.reason}`;
          reasonSpan.setAttribute("data-i18n", i18nReason);
          return;
        }
      });
    }

    disconnectedCallback() {
      this.unsub?.();
    }
  }

  customElements.define("server-error-card", ServerErrorCard);
</script>

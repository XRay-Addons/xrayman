---
import TitleLoggedOut from "./TitleLoggedOut.astro";
import ChooseNameCard from "./ChooseNameCard.astro";
import ShareDialogCard from "./ShareDialogCard.astro";
---

<page-logged-out hidden>
  <TitleLoggedOut />
  <ChooseNameCard />
  <ShareDialogCard />
</page-logged-out>

<script>
  import { stateSignal } from "@/state/signals";
  import { State } from "@/state/state";

  class PageLoggedOut extends HTMLElement {
    private unsub?: () => void;

    connectedCallback() {
      this.unsub = stateSignal.subscribe((state) => {
        this.hidden = !(state.status === State.LoggedOut);
      });
    }

    disconnectedCallback() {
      this.unsub?.();
    }
  }

  customElements.define("page-logged-out", PageLoggedOut);
</script>

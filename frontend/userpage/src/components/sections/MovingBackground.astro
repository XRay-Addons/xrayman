---
export interface Props {
  src: string;
}

const { src } = Astro.props;
---

<div class="cover">
  <div class="bg" style={`background-image: url(${src});`}></div>

  <div class="content">
    <slot />
  </div>
</div>

<style>
  .cover {
    position: relative;
    min-height: 100vh;
    isolation: isolate;
  }

  .bg {
    position: fixed;
    inset: 0;
    opacity: 100%;

    background-size: cover;
    background-repeat: no-repeat;

    z-index: -1;
    animation: moveBackground 4s ease-in-out infinite alternate;
  }

  @keyframes moveBackground {
    0% {
      background-position: 0% 0%;
    }
    100% {
      background-position: 100% 100%;
    }
  }
  .content {
    position: relative;
    z-index: 1;
  }
</style>

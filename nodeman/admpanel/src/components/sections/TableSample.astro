---
import PropsTable from "../ui/PropsTable.astro";
import { h } from "vue";

const statusRender = ({ text }) =>
  h("span", { class: ["status", text] }, [
    h("span", { class: "dot" }),
    h("span", { class: "label" }, text),
  ]);

const columns = [
  { title: "ID", dataIndex: "id" },
  { title: "Host", dataIndex: "host" },
  {
    title: "Status",
    dataIndex: "status",
    customRender: statusRender,
  },
];
---

<table-sample>
  <PropsTable
    headers={["ID", "Status", "CPU"]}
    datacells={["id", "status", "stats.cpu.usage"]}
  />
</table-sample>


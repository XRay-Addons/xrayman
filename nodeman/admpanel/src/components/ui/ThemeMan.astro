<theme-man> </theme-man>

<style>
  theme-man {
    display: contents;
  }
</style>

<script>
  import palettes from "../../data/palettes/palettes.json";
  import { Colors, setColors, type SetColorPayload } from "../globals/colors";

  class ThemeMan extends HTMLElement {
    doubleTapTimeout: number = 300;
    lastTap = 0;

    connectedCallback() {
      document.addEventListener("click", this.onClick);
    }

    disconnectedCallback() {
      document.removeEventListener("click", this.onClick);
    }

    onClick = () => {
      const now = Date.now();
      if (now - this.lastTap < this.doubleTapTimeout) {
        console.log("set colors");
        setColors(this.getRandomTheme());
      }
      this.lastTap = now;
    };

    getRandomTheme(): SetColorPayload[] {
      const palette = this.getRandomPalette();
      this.randomShuffle(palette);

      const n = palette.length;
      if (n == 0) {
        return [];
      }

      return [
        { color: Colors.BG, value: palette[0 % n] },
        { color: Colors.Card, value: palette[1 % n] },
        { color: Colors.Title, value: palette[2 % n] },
        { color: Colors.Button, value: palette[3 % n] },
        { color: Colors.Input, value: palette[4 % n] },
        { color: Colors.Table, value: palette[5 % n] },
      ];
    }

    getRandomPalette(): string[] {
      return palettes[Math.floor(Math.random() * palettes.length)];
    }

    randomShuffle(palette: string[]) {
      palette.sort(() => Math.random() - 0.5);
    }
  }

  customElements.define("theme-man", ThemeMan);
</script>

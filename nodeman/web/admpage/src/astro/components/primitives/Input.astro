---
import Surface from "./Surface.astro";
import HCenter from "./HCenter.astro";

interface Props {
  inClass?: string;
  outClass?: string;
}

const { inClass = "", outClass = "", ...rest } = Astro.props;
---

<HCenter class={outClass}>
  <Surface depth="var(--input-depth)" color="var(--input-color)">
    <input
      class:list={["ui-reset-input text-md w-100 p-2", inClass]}
      type="text"
      {...rest}
    />
  </Surface>
</HCenter>

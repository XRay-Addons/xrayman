---
import Surface from "./Surface.astro";

interface Props {
  class?: string;
  style?: string;
}
const { class: _class, style: _style, ...rest } = Astro.props;
---

<Surface depth="var(--input-depth)" color="var(--input-color)">
  <input class="ui-reset-input text-md w-100 p-2" type="text" {...rest} />
</Surface>

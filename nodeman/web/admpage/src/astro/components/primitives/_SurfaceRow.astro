---
import Surface from "./Surface.astro";

interface Props {
  class?: string;
}

const { class: extraClass = "", ...rest } = Astro.props;
---

<div class="app-surface-row__wrap h-center">
  <div
    class:list={[
      "app-surface-row  col-12 col-md-10 col-lg-8 row p-1 g-0",
      extraClass,
    ]}
    {...rest}
  >
    <slot />
  </div>
</div>

<style>
  .app-input__field {
    width: 75%;
  }

  .app-input__button {
    width: calc(25% + var(--input-depth));
    margin-left: calc(-1 * var(--input-depth));
  }
</style>

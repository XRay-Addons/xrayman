---
import Title from "@xrayman/shared/astro/components/primitives/Title.astro";
import Card from "@xrayman/shared/astro/components/primitives/Card.astro";
import I18NText from "@xrayman/shared/astro/components/primitives/I18nText.astro";
import UsersTable from "@/vue/components/islands/users-table/UsersTable.vue";
import AddUserDialog from "./AddUserDialog.astro";
---

<div class="col-12 col-md-6 col-lg-5 mb-2">
  <Card class="w-100">
    <Title class="col-6 mb-2">
      <I18NText data-i18n="cards.users.title" />
    </Title>

    <UsersTable client:only="vue" />

    <AddUserDialog />
  </Card>
</div>

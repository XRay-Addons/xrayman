{
  "name": "frontend",
  "private": true,
  "workspaces": [
    "admpage",
    "userpage",
    "shared"
  ],
  "scripts": {
    "gen:admin": "pnpm -F admpage run api:generate",
    "gen:user": "pnpm -F userpage run api:generate",
    "gen": "pnpm run gen:admin && pnpm run gen:user",
    "build:admin": "pnpm -F admpage build",
    "build:user": "pnpm -F userpage build",
    "build": "pnpm run build:user && pnpm run build:admin"
  },
  "dependencies": {
    "pnpm": "^10.33.2"
  }
}

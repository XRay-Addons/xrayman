---
import Title from "../ui/Title.astro";
---

<title-logged-in>
  <Title class="mb-2">
    <span data-i18n="title.hello"></span>
    <span part="username"></span>
  </Title>
</title-logged-in>

<style>
  title-logged-in {
    display: contents;
  }
</style>

<script>
  import { apiSignal } from "../../stores/api-signal";

  class TitleLoggedIn extends HTMLElement {
    private unsub?: () => void;

    connectedCallback() {
      const usernameEl = this.querySelector<HTMLElement>('[part="username"]');
      if (!usernameEl) return;

      this.unsub = apiSignal.subscribe((state) => {
        if (state.status === "logged-in") {
          usernameEl.textContent = state.data.displayName;
        } else {
          usernameEl.textContent = "";
        }
      });
    }

    disconnectedCallback() {
      this.unsub?.();
    }
  }

  customElements.define("title-logged-in", TitleLoggedIn);
</script>

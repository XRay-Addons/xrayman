<user-controller> </user-controller>

<style>
  page-content {
    display: contents;
  }
</style>

<script>
  import { ProfileURL, ProfileStorage, UserUtils } from "../../lib/user-utils";
  import { apiSignal } from "../../stores/api-signal";
  import { getUser } from "../../api/client";
  import { API_REASON } from "../../lib/types";

  class UserController extends HTMLElement {
    private unsub?: () => void;

    private async init() {
      // url user priority
      const userID = ProfileURL.parse() || ProfileStorage.parse();
      if (!userID) {
        apiSignal.set({ status: "logged-out" });
        return;
      }
      const userResponse = await getUser(userID);
      if (userResponse.ok) {
        const user = UserUtils.makeUser(userResponse.data);
        apiSignal.set({ status: "logged-in", data: user });
      } else if (
        userResponse.ok == false &&
        userResponse.reason == API_REASON.NOT_FOUND
      ) {
        apiSignal.set({ status: "logged-out" });
      } else if (userResponse.ok == false) {
        apiSignal.set({ status: "server-error", error: userResponse.reason });
      }
    }

    connectedCallback() {
      this.unsub = apiSignal.subscribe((state) => {
        if (state.status === "logged-in") {
          ProfileURL.set(state.data);
          ProfileStorage.set(state.data);
        } else if (state.status === "logged-out") {
          ProfileURL.reset();
          ProfileStorage.reset();
        } else if (state.status == "idle") {
          this.init();
        }
      });
    }

    disconnectedCallback() {
      this.unsub?.();
    }
  }

  customElements.define("user-controller", UserController);
</script>

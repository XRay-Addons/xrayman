---
import LazyImg from "./LazyImg.astro";

const {
  src = "",
  color = "white",
  class: extraClass = "",
  ...rest
} = Astro.props;

const styleVars = {
  ...(color && { "--text-color": color }),
};
---

<div
  class:list={["d-flex justify-content-center", extraClass]}
  {...rest}
  style={styleVars}
>
  <div class="position-relative col-10">
    <LazyImg class="w-100" src={src} />

    <div class="position-absolute error-text v-center h-center flex-column">
      <slot />
    </div>
  </div>
</div>

<style>
  .error-text {
    inset: 0;
    color: var(--text-color);
    font-size: 24px;
    font-weight: bold;
    text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.7);
  }
</style>

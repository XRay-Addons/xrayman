---
import ErrorImg from "@/components/ui/ErrorImg.astro";

const errorImg = "./error.gif";
const errorColor = "white";
---

<server-error>
  <ErrorImg src={errorImg} color={errorColor}>
    <div data-i18n="servererror.main"></div>
    <div part="servererror.reason"></div>
  </ErrorImg>
</server-error>

<style>
  server-error {
    display: contents;
  }
</style>

<script>
  import { stateSignal } from "@/lib/state-signals";

  class ServerError extends HTMLElement {
    private unsub?: () => void;

    connectedCallback() {
      const reasonSpan = this.querySelector<HTMLSpanElement>('[part="servererror.reason"]');
      if (!reasonSpan) return;

      this.unsub = stateSignal.subscribe((state) => {
        if (state.status === "server-error") {
          const i18nReason = `servererror.reason.${state.reason}`;
          reasonSpan.setAttribute("data-i18n", i18nReason);
          return;
        }
      });
    }

    disconnectedCallback() {
      this.unsub?.();
    }
  }

  customElements.define("server-error", ServerError);
</script>

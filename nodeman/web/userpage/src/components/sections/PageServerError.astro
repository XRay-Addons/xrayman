---
import ServerError from "./ServerError.astro";
---

<page-server-error hidden>
  <ServerError />
</page-server-error>

<script>
  import { stateSignal } from "@/lib/state-signals";

  class PageServerError extends HTMLElement {
    private unsub?: () => void;

    connectedCallback() {
      this.unsub = stateSignal.subscribe((state) => {
        this.hidden = !(state.status === "server-error");
      });
    }

    disconnectedCallback() {
      this.unsub?.();
    }
  }

  customElements.define("page-server-error", PageServerError);
</script>

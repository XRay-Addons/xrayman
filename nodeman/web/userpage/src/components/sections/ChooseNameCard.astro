---
import Card from "@/components/ui/Card.astro";
import Info from "@/components/ui/Info.astro";
import InputGroup from "@/components/ui/InputGroup.astro";
import InputText from "@/components/ui/InputText.astro";
import InputButton from "@/components/ui/InputButton.astro";
---

<choose-name-card>
  <Card class="mb-2">
    <Info data-i18n="choosename.info" />
    <InputGroup>
      <InputText slot="input" data-i18n-placeholder="choosename.placeholder" part="name-input" />
      <InputButton slot="button" part="name-input-btn" data-i18n="choosename.btntext" />
    </InputGroup>
  </Card>
</choose-name-card>

<style>
  title-logged-in {
    display: contents;
  }
</style>

<script>
  import { newUser } from "@/services/api/client";
  import { UserUtils } from "@/lib/user-utils";
  import { stateSignal } from "@/lib/state-signals";

  class ChooseNameCard extends HTMLElement {
    connectedCallback() {
      const inputEl = this.querySelector<HTMLInputElement>('[part="name-input"]');
      const btnEl = this.querySelector<HTMLButtonElement>('[part="name-input-btn"]');
      if (!inputEl || !btnEl) return;

      const onSubmit = async () => {
        const displayName = inputEl.value.trim();
        if (!displayName) return;

        const userResponse = await newUser(displayName);
        if (userResponse.ok) {
          const user = UserUtils.makeUser(userResponse.data);
          stateSignal.set({ status: "logged-in", data: user });
        } else if (userResponse.ok == false) {
          // WTF typescript conditions
          stateSignal.set({
            status: "server-error",
            reason: userResponse.reason,
          });
        }
      };

      btnEl.addEventListener("click", onSubmit);
      inputEl.addEventListener("keydown", (e) => e.key === "Enter" && onSubmit());
    }
  }

  customElements.define("choose-name-card", ChooseNameCard);
</script>

<user-controller> </user-controller>

<script>
  import { ProfileURL, ProfileStorage } from "@/runtime/user/user-utils";
  import { stateSignal } from "@/state/signals";
  import { getUser } from "@/services/api/client";
  import { API_REASON } from "@xrayman/shared/services/api/api-reason";
  import { State } from "@/state/state";
  import { notifyError } from "@/runtime/notifications/use-notifications";

  class UserController extends HTMLElement {
    private unsub?: () => void;

    private async init() {
      // url user priority
      const userID = ProfileURL.parse() || ProfileStorage.parse();
      if (!userID) {
        stateSignal.set({ status: State.LoggedOut });
        return;
      }
      const userResponse = await getUser(userID.id, userID.name);
      if (userResponse.ok) {
        if (userResponse.data.TargetStatus === "enabled") {
          stateSignal.set({ status: State.LoggedIn, data: userResponse.data });
        } else {
          notifyError("client.error.disabled");
          // user disabled or deleted or whateverelse
          stateSignal.set({ status: State.LoggedOut });
        }
      } else if (userResponse.ok == false && userResponse.reason == API_REASON.NOT_FOUND) {
        stateSignal.set({ status: State.LoggedOut });
      } else if (userResponse.ok == false) {
        stateSignal.set({
          status: State.ServerError,
          reason: userResponse.reason,
        });
      }
    }

    connectedCallback() {
      this.unsub = stateSignal.subscribe((state) => {
        if (state.status === State.LoggedIn) {
          ProfileURL.set(state.data);
          ProfileStorage.set(state.data);
        } else if (state.status === State.LoggedOut) {
          ProfileURL.reset();
          ProfileStorage.reset();
        } else if (state.status == "idle") {
          this.init();
        }
      });
    }

    disconnectedCallback() {
      this.unsub?.();
    }
  }

  customElements.define("user-controller", UserController);
</script>

---
import Surface from "./Surface.astro";

interface Props {
  class?: string;
  style?: string;
}
const { class: extraClass, style: __, ...rest } = Astro.props;
---

<Surface depth="var(--input-depth)" color="var(--input-color)" class={extraClass}>
  <input class="ui-reset-input w-100 text-md p-2" type="text" {...rest} />
</Surface>
